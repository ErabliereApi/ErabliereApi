{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "ErabliereApi": {
      "commandName": "Project",
      "launchBrowser": false,
      "launchUrl": "api",
      "applicationUrl": "https://0.0.0.0:5001;http://0.0.0.0:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "USE_CORS": "True",
        "CORS_HEADERS": "*",
        "CORS_METHODS": "*",
        "CORS_ORIGINS": "*",
        "SQL_CONNEXION_STRING": "Server=(localdb)\\mssqllocaldb;Database=ErabliereAPIV3;Integrated Security=true",
        "SQL_USE_STARTUP_MIGRATION": "true",
        "DEBUG_HEADERS": "true",
        "LOG_SQL": "-",
        "USE_AUTHENTICATION": "true",
        "USE_SWAGGER_AUTHORIZATIONCODE_WORKFLOW": "true",
        "USE_SWAGGER_PKCE": "true",
        "MiniProfiler.Enable": "false",
        "MiniProlifer.EntityFramework.Enable": "false",
        "Kestrel:Limits:MaxRequestHeaderCount": "80",
        "Kestrel:Limits:MinRequestBodyDataRate:BytesPerSecond": "300",
        "USE_CHAOS_ENGINEERING": "false",
        "ChaosEngineeringPercent": "0.1"
      }
    }
  }
}
